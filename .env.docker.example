# icore docker-compose env — copy to .env.docker and fill creds before booting.
# Transport is hard-wired to redis in the compose file (services share a redis
# broker). Provider credentials map 1:1 with each MS's .env.example.

# ── Auth MS ─────────────────────────────────────────────────────────────────
AUTH_PROVIDER=supabase
ADMINS_LIST=

# Supabase (when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase (when AUTH_PROVIDER=firebase or STORAGE_PROVIDER=firebase)
FB_ADMIN_PROJECT_ID=
FB_ADMIN_CLIENT_EMAIL=
FB_ADMIN_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=

# OAuth (Firebase path only; Supabase configures in its dashboard)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ── Upload MS ───────────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=uploads

# Cloudinary (when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Gateway ─────────────────────────────────────────────────────────────────
# Where the client SPA runs (used as the magic-link / OAuth callback redirect).
CLIENT_ORIGIN=http://localhost:4200
API_ORIGIN=http://localhost:3001

# Throttle salt / NODE_ENV
NODE_ENV=production

# ── Jobs MS (BullMQ) ────────────────────────────────────────────────────────
JOBS_REDIS_URL=redis://redis:6379
JOBS_WORKER_CONCURRENCY=5
