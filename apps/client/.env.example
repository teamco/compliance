# ─── Client environment variables ────────────────────────────────────────
# API gateway base URL.
#   /api   — default; dev-server proxies it to http://localhost:3001 (see vite.config.mts)
#   http://localhost:3001/api — set explicitly if you want to bypass the proxy
#   https://your-domain.com/api — production override when building a standalone SPA
VITE_API_URL=/api

# iSubscribe tenant API key. Required for the live SubscriptionWidget on
# the landing's pricing section. Generate via the dashboard
# (apps/client → Tenants → Generate API key) using the tenant that owns
# the iSubscribe-as-product subscriptions we want to showcase.
VITE_PUBLIC_TENANT_KEY=
