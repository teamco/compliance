{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/client/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project client --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/client",
        "command": "vite build"
      },
      "cache": true,
      "inputs": ["production", "^production", { "externalDependencies": ["vite"] }],
      "outputs": ["{workspaceRoot}/dist/apps/client"],
      "dependsOn": ["^build"]
    }
  }
}
